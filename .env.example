# Gemini API Key (Required)
GEMINI_API_KEY="your_google_gemini_api_key_here"

# (Optional) Audio Devices Configuration
# Leave blank to let the system auto-detect "BlackHole 2ch" and the default speaker
# Or specify the exact device indices (run `python audio_manager.py` to list indices)
INPUT_DEVICE_INDEX=
OUTPUT_DEVICE_INDEX=
MONITOR_DEVICE_INDEX=

# Gemini Voice Name (Options: Puck, Charon, Kore, Fenrir, Aoede)
VOICE_NAME="Puck"
